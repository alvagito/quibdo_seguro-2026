{
    "name": "quibdo/analytics-service",
    "description": "Quibdó Seguro - Servicio de Estadísticas y Analytics",
    "type": "project",
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.10",
        "mongodb/laravel-mongodb": "^5.5",
        "guzzlehttp/guzzle": "^7.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
